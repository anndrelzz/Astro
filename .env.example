# Copie este arquivo para .env e preencha os valores.
# Nunca commitar o .env real (ja esta no .gitignore).

# PostgreSQL (Azure Database for PostgreSQL em producao; local ou `npx prisma dev` em dev)
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/astro?schema=public"

# NextAuth — gerar com: npx auth secret (ou `openssl rand -base64 32`)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Resend — envio de e-mails transacionais (M3)
RESEND_API_KEY=""

# Telegram Bot API — notificacoes opcionais (M3). Sem token, roda em modo log.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME="AstroBot"

# Segredo simples para proteger o endpoint /api/cron/lembretes ate existir
# infra de agendamento real (M5)
CRON_SECRET=""
